# CKB network: testnet | mainnet
NEXT_PUBLIC_CKB_NETWORK=testnet

# Optional custom RPC endpoint (leave empty to use CCC defaults)
NEXT_PUBLIC_CKB_RPC_URL=

# Deployment of the four-gods contract binary on CKB.
# HASH_TYPE should be "data", "data1", or "type".
NEXT_PUBLIC_FOUR_GODS_CODE_HASH=0xa0c18926cc73f9d919288863cd628206e80b5212bd42ef8d7153b564d8baaad8
NEXT_PUBLIC_FOUR_GODS_HASH_TYPE=data1
NEXT_PUBLIC_FOUR_GODS_TX_HASH=<deploy_tx_hash>
NEXT_PUBLIC_FOUR_GODS_TX_INDEX=0
